{
  "devDependencies": {
    "@next/env": "^16.2.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "dotenv-cli": "^7.4.4",
    "esbuild": "^0.27.7",
    "jsdom": "^29.1.1",
    "picomatch": "^4.0.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.19",
    "turbo": "^2.9.14"
  },
  "packageManager": "npm@11.3.0",
  "name": "nowflow-workspace",
  "version": "0.0.0",
  "description": "NowFlow Community Edition monorepo.",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  },
  "workspaces": [
    "apps/nowflow",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=nowflow",
    "dev:all": "turbo run dev",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:assets": "bash scripts/check-public-assets.sh apps/nowflow/public",
    "lint": "turbo run lint",
    "dev:fallback": "turbo run dev",
    "build:fallback": "turbo run build",
    "db:check": "node scripts/check-db.js"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "postcss": "^8.5.15",
    "fast-uri": "^3.1.2",
    "vite": "^8.0.14",
    "engine.io": "^6.6.8",
    "socket.io-adapter": "^2.5.7",
    "ws": "^8.20.1",
    "mammoth": {
      "@xmldom/xmldom": "^0.8.13"
    },
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "readdirp": {
      "picomatch": "^2.3.2"
    },
    "tinyglobby": {
      "picomatch": "^4.0.4"
    },
    "vitest": {
      "picomatch": "^4.0.4",
      "vite": "^8.0.14"
    },
    "@vitest/mocker": {
      "vite": "^8.0.14"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/react": "^19.2.14",
    "@xyflow/react": "^12.10.1",
    "csstype": "^3.2.3",
    "drizzle-orm": "^0.45.2",
    "estree-walker": "^3.0.3",
    "impit": "^0.11.0",
    "react": "19.1.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "simple-icons": "^15.20.0",
    "youtube-transcript": "^1.3.0"
  },
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs"
}
