    "lib/auth/providers/sap.ts",
    "lib/auth/providers/social.ts",
    "lib/auth/providers/trusted.ts",
    "lib/auth/types.ts",
    "lib/oauth/revoke.ts",
    "lib/webhooks/secret.ts",
    "lib/utils/encryption.ts",
