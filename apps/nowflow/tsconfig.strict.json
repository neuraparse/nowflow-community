{
  "//": "===================================================================",
  "//1": "Staged-rollout strict TypeScript config.",
  "//2": "",
  "//3": "Background: the main tsconfig.json has \"strict\": false because the app",
  "//4": "currently contains ~2,908 implicit-any annotations and ~1,353 `as any`",
  "//5": "casts. Flipping strict mode globally would surface thousands of errors",
  "//6": "at once and block all work. Instead, this config enables strict mode",
  "//7": "ONLY for a curated allow-list of files that are already type-clean",
  "//8": "(recently audited helpers, small utilities, and barrel re-exports).",
  "//9": "",
  "//A": "Workflow:",
  "//B": "  1. Run `npx tsc -p tsconfig.strict.json --noEmit` locally / in CI.",
  "//C": "  2. As more files are made strict-clean, add them to `include` below.",
  "//D": "  3. Once the include set covers most of the app, replace this with",
  "//E": "     `\"strict\": true` in the base tsconfig.json and delete this file.",
  "//F": "",
  "//G": "Errors in unlisted dependency files are tolerated: tsc still loads them",
  "//H": "for type resolution but does not enforce strict diagnostics on them.",
  "//I": "===================================================================",
  "//api-todo": "TODO: app/api/chat/[subdomain]/analytics is excluded with >10 implicit-any errors (Drizzle row widening + untyped aggregates). Revisit after typing common analytics helpers.",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noEmit": true
  },
  "include": [
    "lib/api/route-helpers.ts",
    "lib/api/__tests__/access-matrix.test.ts",
    "lib/api/__tests__/route-helpers.test.ts",
