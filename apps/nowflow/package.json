{
  "name": "nowflow",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "dev:classic": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:ensure-vector": "tsx scripts/ensure-pgvector.ts",
    "db:push": "npm run db:ensure-vector && drizzle-kit push",
    "db:seed": "npx tsx scripts/seed-examples.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:studio": "drizzle-kit studio",
    "db:migrate-files": "npx tsx scripts/migrate-knowledge-to-files.ts",
    "test": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "email:dev": "email dev --dir components/emails",
    "check-types": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "dev:all": "npm run dev"
  },
