{
  "compilerOptions": {
    "strict": false,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "exclude": ["node_modules", "apps", "packages"]
}
