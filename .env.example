# Nowflow Community example environment
# Copy to .env for local development. Do not commit real secrets.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENTERPRISE_URL=https://nowflow.io
NEXT_PUBLIC_SUPPORT_EMAIL=support@nowflow.io
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=
JWT_SECRET=

# Database
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PASSWORD=

# Email
RESEND_API_KEY=
SUPPORT_EMAIL=support@nowflow.io

# AI providers (bring your own key)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# OAuth integrations (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Community runtime
CODE_RUNNER=quickjs
OAUTH_ALLOWED_REDIRECT_URIS=
