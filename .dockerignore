# Exclude files from Docker build
.git
.github
**/node_modules
.next
**/.next
**/.next/
**/.next/cache
**/node_modules/.cache
.turbo
**/.turbo
**/.turbo/
.vercel
.husky
.env
.env.*
!.env.example
!**/.env.example
npm-debug.log
README.md

# Platform-specific files that can cause issues
.DS_Store
Thumbs.db
*.node
*.dylib
*.so
*.dll

# Build outputs and caches
dist/
**/dist/
build/
**/build/
out/
**/out/
.cache/
**/.cache/
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
*.tsbuildinfo
**/*.tsbuildinfo

# Logs and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
*.lcov
.nyc_output
test-results/
playwright-report/
blob-report/

